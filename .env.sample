# Postgres (local docker) — Slice 1
POSTGRES_USER=paperless
POSTGRES_PASSWORD=paperless
POSTGRES_DB=paperless
POSTGRES_PORT=5432
DATABASE_URL=postgresql://paperless:paperless@localhost:5432/paperless

# LLM providers (used from Slice 4+ — not needed for the schema)
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Retrieval (Slice 8): context-aware query reformulation. "none" = passthrough.
# REFORMULATION_PROVIDER=anthropic
# Hybrid retrieval tuning (defaults in retrieval-api/app/config.py):
# RETRIEVAL_TOP_K=10  MIN_CHUNK_CHARS=30  RRF_K=60  OVER_FETCH_MULTIPLIER=6

# Embedding (Slice 2+)
# EMBEDDING_MODEL=intfloat/multilingual-e5-large

# --- GitHub OAuth (paperless-ui / nuxt-auth-utils) ---
# NUXT_SESSION_PASSWORD: khoá mã hoá cookie phiên, >=32 ký tự (openssl rand -hex 24)
NUXT_SESSION_PASSWORD=
# Tạo GitHub OAuth App: callback = http://localhost:3100/api/auth/github
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=
