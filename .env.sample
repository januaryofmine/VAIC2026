# Template — copy sang .env rồi điền. KHÔNG bao giờ commit .env thật.
# Xem TEAM_SETUP.md để biết cách lấy từng key + cách chia sẻ an toàn cho team.

# ── Postgres local (docker-compose) ───────────────────────────
POSTGRES_USER=paperless
POSTGRES_PASSWORD=paperless
POSTGRES_DB=paperless
POSTGRES_PORT=5432
# Local: postgresql://paperless:paperless@localhost:5432/paperless
# Cloud (Supabase pooler): postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://paperless:paperless@localhost:5432/paperless

# ── Embedding provider ────────────────────────────────────────
# EMBEDDING_PROVIDER=e5            # "e5" (local sentence-transformers) | "gemini" (API, torch-free)
# GEMINI_API_KEY=                 # nếu dùng gemini — aistudio.google.com/apikey
# EMBEDDING_MODEL=intfloat/multilingual-e5-large

# ── LLM providers ─────────────────────────────────────────────
# ANTHROPIC_API_KEY=              # console.anthropic.com
# REFORMULATION_PROVIDER=anthropic  # "none" = passthrough

# ── Hybrid retrieval tuning (mặc định ở retrieval-api/app/config.py) ──
# RETRIEVAL_TOP_K=10  MIN_CHUNK_CHARS=30  RRF_K=60  OVER_FETCH_MULTIPLIER=6

# ── Reranker (optional 2nd stage, self-host torch) ────────────
# RERANKER_ENABLED=false
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3   # hoặc path tới model LoRA đã fine-tune

# ── GitHub OAuth (paperless-ui / nuxt-auth-utils) ─────────────
# NUXT_SESSION_PASSWORD: khoá mã hoá cookie phiên, >=32 ký tự (openssl rand -hex 24)
NUXT_SESSION_PASSWORD=
# Tạo GitHub OAuth App: callback = http://localhost:3100/api/auth/github
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=

# ── retrieval-api (RAG engine) mà paperless-ui gọi qua HTTP ───
# Local: http://localhost:8001 ; Cloud: https://<user>-<space>.hf.space
NUXT_RETRIEVAL_API_HOST=http://localhost:8001
# Shared secret khớp API_KEY trên retrieval-api (rỗng ở local = endpoint mở)
NUXT_RETRIEVAL_API_KEY=
# API_KEY=                        # đặt trên retrieval-api công khai (cổng X-API-Key)

# ── Serving / deploy ──────────────────────────────────────────
# CORS_ORIGINS=["https://<ui>.vercel.app"]
# HF_USER=                        # deploy HF Space / tải model
# HF_TOKEN=                       # token Write
